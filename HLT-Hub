                    VIM:SendMouseButtonEvent(mid.X, mid.Y, 0, false, game, 1)
                end
            end)
        end
    end
end)

-- 3. Gom Quái (Bring Mob)
task.spawn(function()
    while task.wait(0.5) do
        if _G.AutoFarm and _G.BringMob and _G.TargetMob ~= "" then
            pcall(function()
                local mainMob = GetMob()
                if mainMob then
                    local targetPos = mainMob.HumanoidRootPart.CFrame
                    for _, v in pairs(workspace:GetDescendants()) do
                        if v:IsA("Model") and v.Name == _G.TargetMob and v ~= mainMob and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                            v.HumanoidRootPart.CFrame = targetPos -- Hút về 1 chỗ
                        end
                    end
                end
            end)
        end
    end
end)

