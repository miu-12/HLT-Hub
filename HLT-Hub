            if _G["Skill"..key] then
                VIM:SendKeyEvent(true, Enum.KeyCode[key], false, game)
                task.wait(0.05)
                VIM:SendKeyEvent(false, Enum.KeyCode[key], false, game)
            end
        end
    end)
end

