local function GetTarget()
    local target, dist = nil, math.huge
    local pChar = game.Players.LocalPlayer.Character
    if not pChar or not pChar:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = pChar.HumanoidRootPart.Position

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v ~= pChar then
            if _G.KillAura or (_G.AutoFarm and v.Name == _G.TargetMob) then
                local d = (myPos - v.HumanoidRootPart.Position).Magnitude
                if d < dist then dist, target = d, v end
            end
        end
    end
    return target
end

task.spawn(function()
    while task.wait(0.05) do
        if (_G.AutoFarm or _G.KillAura) and game.Players.LocalPlayer.Character then
            pcall(function()
                local char = game.Players.LocalPlayer.Character
                local root = char.HumanoidRootPart
                local target = GetTarget()
                if target and char.Humanoid.Health > 0 then
                    root.Velocity = Vector3.new(0, 0, 0)
                    root.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 7, 0)
                    local tool = char:FindFirstChildOfClass("Tool")
                    if tool then 
                        tool:Activate() 
                        if _G.AutoHit then VU:Button1Click(Vector2.new(0,0)) end
                    end
                end
            end)
        end
    end
end)

task.spawn(function()
