-- 1. Tìm quái
local function GetMob()
    local target, dist = nil, math.huge
    local pChar = game.Players.LocalPlayer.Character
    if not pChar or not pChar:FindFirstChild("HumanoidRootPart") or _G.TargetMob == "" then return nil end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name == _G.TargetMob and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            local d = (pChar.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
            if d < dist then dist, target = d, v end
        end
    end
    return target
end

