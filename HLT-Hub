local function GetMob()
    local target, dist = nil, math.huge
    local pChar = game.Players.LocalPlayer.Character
    if not pChar or not pChar:FindFirstChild("HumanoidRootPart") or _G.TargetMob == "" then return nil end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name == _G.TargetMob and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            local d = (pChar.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
            if d < dist then dist, target = d, v end
        end
    end
    return target
end

-- VÒNG LẶP CHÍNH (Kết hợp AI Sinh Tồn)
task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoFarm and _G.TargetMob ~= "" then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local char = lp.Character
                local root = char.HumanoidRootPart
                local hum = char.Humanoid
                
                -- HỆ THỐNG AI SINH TỒN
                if _G.AISurvival then
                    if hum.Health <= (hum.MaxHealth * 0.3) then -- Dưới 30% máu
                        _G.IsHealing = true
                    elseif hum.Health >= (hum.MaxHealth * 0.9) then -- Hồi trên 90% máu
                        _G.IsHealing = false
                    end
                else
                    _G.IsHealing = false -- Nếu tắt AI thì dập tắt trạng thái
                end

                -- NẾU ĐANG CHẠY TRỐN ĐỂ HỒI MÁU
                if _G.IsHealing then
                    root.Velocity = Vector3.new(0, 0, 0)
                    -- Bay tuốt lên trời 50 mét chờ hồi máu
                    root.CFrame = root.CFrame * CFrame.new(0, 50, 0)
                    return -- Dừng việc đánh quái ở dưới lại
                end

                -- NẾU KHÔNG PHẢI HỒI MÁU THÌ ĐÁNH TIẾP
                local target = GetMob()
                if target and hum.Health > 0 then
                    root.Velocity = Vector3.new(0, 0, 0)
                    root.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 7, 0) 
                    
                    local tool = char:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end 
                    
                    local cam = workspace.CurrentCamera
                    local mid = cam.ViewportSize / 2
                    VIM:SendMouseButtonEvent(mid.X, mid.Y, 0, true, game, 1) 
                    task.wait(0.01)
                    VIM:SendMouseButtonEvent(mid.X, mid.Y, 0, false, game, 1)
                end
            end)
        end
    end
end)

-- AI AUTO FLEX CHAT (Gáy khi quái chết)
task.spawn(function()
    while task.wait(2) do
        if _G.AutoFarm and _G.AIFlexChat then
            pcall(function()
                local pChar = game.Players.LocalPlayer.Character
                if pChar then
                    -- Quét xem quanh mình có xác con nào vừa chết không
                    for _, v in pairs(workspace:GetDescendants()) do
                        if v:IsA("Model") and v.Name == _G.TargetMob and v:FindFirstChild("Humanoid") then
                            if v.Humanoid.Health <= 0 then
                                -- Đo khoảng cách, nếu chết gần mình thì gáy
                                local dist = (pChar.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
                                if dist < 20 then
                                    local messages = {
                                        "Đụng vào HLT Kem Đẹp zai là dở rồi!",
                                        "Tuổi gì đòi ăn được anh?",
                                        "Bản Hub VIP này mạnh quá, quái khóc thét!",
                                        "Sếp HLT Kem Đẹp zai muôn năm!"
