end)

-- GOM QUÁI
task.spawn(function()
    while task.wait(0.5) do
        if _G.AutoFarm and _G.BringMob and _G.TargetMob ~= "" and not _G.IsHealing then
            pcall(function()
                local mainMob = GetMob()
                if mainMob then
                    local targetPos = mainMob.HumanoidRootPart.CFrame
