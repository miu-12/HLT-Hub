-- HÀM TẠO TAB MỚI
local function CreateTab(name, pos)
    local btn = Instance.new("TextButton", TabPanel)
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.Position = UDim2.new(0, 0, 0, pos * 40)
    btn.Text = name
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    
    local content = Instance.new("ScrollingFrame", ContentFrame)
    content.Size = UDim2.new(1, 0, 1, 0)
    content.BackgroundTransparency = 1
    content.Visible = false
    content.ScrollBarThickness = 3
    local list = Instance.new("UIListLayout", content)
    list.Padding = UDim.new(0, 5)
    
    btn.MouseButton1Click:Connect(function()
        for _, v in pairs(ContentFrame:GetChildren()) do v.Visible = false end
        content.Visible = true
        for _, v in pairs(TabPanel:GetChildren()) do if v:IsA("TextButton") then v.BackgroundColor3 = Color3.fromRGB(25, 25, 25) end end
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    end)
    return content, btn
end

-- HÀM TẠO TOGGLE (BẬT/TẮT Y CHANG DELTA)
local function CreateToggle(txt, parent, varName)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, 0, 0, 35)
    frame.BackgroundTransparency = 1
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.8, 0, 1, 0)
    label.Text = txt
    label.Font = Enum.Font.GothamBold
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.BackgroundTransparency = 1
    local toggleBtn = Instance.new("TextButton", frame)
    toggleBtn.Size = UDim2.new(0.15, 0, 0.8, 0)
    toggleBtn.Position = UDim2.new(0.8, 0, 0.1, 0)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    toggleBtn.Text = ""
    local toggleBox = Instance.new("Frame", toggleBtn)
    toggleBox.Size = UDim2.new(0.9, 0, 0.9, 0)
    toggleBox.Position = UDim2.new(0.05, 0, 0.05, 0)
    toggleBox.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Màu đỏ mặc định (OFF)
    
    toggleBtn.MouseButton1Click:Connect(function()
        _G[varName] = not _G[varName]
        if _G[varName] then
            toggleBox.BackgroundColor3 = Color3.fromRGB(255, 255, 255) -- Màu trắng (ON)
        else
            toggleBox.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Màu đỏ (OFF)
        end
    end)
end

