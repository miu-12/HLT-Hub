-- 2. ĐÁNH XA (HITBOX EXPANDER) - Bơm to gấp 60 lần
task.spawn(function()
    while task.wait(0.5) do
        if _G.Reach then
            pcall(function()
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v ~= lp.Character then
                        local hrp = v:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            hrp.Size = Vector3.new(60, 60, 60)
                            hrp.Transparency = 0.8 -- Hơi tàng hình để đỡ vướng mắt
                            hrp.CanCollide = false
                        end
                    end
                end
            end)
        end
    end
end)

-- 3. KILL AURA VIP (Hút toàn bộ mọi thứ vào kiếm)
task.spawn(function()
    while task.wait() do
        if _G.KillAura and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local myHRP = lp.Character.HumanoidRootPart
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v ~= lp.Character then
                        -- Dịch chuyển toàn bộ mục tiêu ra phía trước mặt người chơi 5 mét
                        v.HumanoidRootPart.CFrame = myHRP.CFrame * CFrame.new(0, 0, -5)
                    end
                end
            end)
        end
    end
end)

-- 4. ĐỨNG TRÊN ĐẦU QUÁI (FARM)
task.spawn(function()
    while task.wait() do
        if _G.AutoFarm and not _G.KillAura and lp.Character then
            pcall(function()
                local target = GetTarget()
                if target then
                    local root = lp.Character.HumanoidRootPart
                    root.Velocity = Vector3.new(0, 0, 0)
                    root.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 7, 0)
                end
            end)
        end
    end
end)

-- 5. SKILL XẢ NHƯ CÁI MÁY KHÂU (Mỗi 0.2 giây / KHÔNG DELAY)
task.spawn(function()
    while task.wait(0.2) do
        if _G.AutoSkill and (_G.AutoFarm or _G.KillAura) and lp.Character then
            pcall(function()
                local keys = {"Z", "X", "C", "V", "F"}
                for _, key in pairs(keys) do
                    if _G["Skill"..key] then
                        task.spawn(function() -- Tách luồng để nhấn cùng lúc
                            VIM:SendKeyEvent(true, Enum.KeyCode[key], false, game)
                            task.wait(0.01)
                            VIM:SendKeyEvent(false, Enum.KeyCode[key], false, game)
                        end)
                    end
                end
            end)
        end
    end
end)

