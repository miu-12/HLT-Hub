local lp = game.Players.LocalPlayer

-- 1. AUTO CLICK
task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoClick and lp.Character then
            pcall(function()
                local tool = lp.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end)
        end
    end
end)

-- 2. KILL AURA (ĐÃ LỌC NPC VÀ TĂNG TẦM LÊN 150M)
task.spawn(function()
    while task.wait(0.1) do
        if _G.KillAura and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local myHRP = lp.Character.HumanoidRootPart
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v ~= lp.Character then
                        -- LỌC NGƯỜI CHƠI (Bỏ qua người chơi khác)
                        if not game.Players:GetPlayerFromCharacter(v) then
                            local nameL = string.lower(v.Name)
                            -- LỌC NPC NHIỆM VỤ, THƯƠNG GIA (Bỏ qua những thứ có chữ npc, quest, giver...)
                            local isNPC = nameL:find("npc") or nameL:find("quest") or nameL:find("giver") or nameL:find("dealer") or nameL:find("seller") or nameL:find("merchant") or nameL:find("citizen")
                            
                            if not isNPC then
                                local hrp = v:FindFirstChild("HumanoidRootPart")
                                if hrp then
                                    local dist = (myHRP.Position - hrp.Position).Magnitude
                                    -- Tầm hút được nới rộng ra 150 mét
                                    if dist < 150 then
                                        hrp.CFrame = myHRP.CFrame * CFrame.new(0, 0, -6) -- Hút ra trước mặt 6m
                                        hrp.Size = Vector3.new(12, 12, 12) -- Làm hitbox quái to lên chút dễ chém
                                        hrp.Transparency = 0.5
                                        hrp.CanCollide = false
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- 3. SMART AUTO SKILL (CŨNG CHỈ TUNG CHIÊU KHI CÓ QUÁI)
task.spawn(function()
    while task.wait(0.5) do
        if _G.AutoSkill and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local myHRP = lp.Character.HumanoidRootPart
                local hasTarget = false
                
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v ~= lp.Character then
                        if not game.Players:GetPlayerFromCharacter(v) then
                            local nameL = string.lower(v.Name)
                            local isNPC = nameL:find("npc") or nameL:find("quest") or nameL:find("giver") or nameL:find("dealer") or nameL:find("merchant")
                            
                            if not isNPC then
                                local hrp = v:FindFirstChild("HumanoidRootPart")
                                if hrp and (myHRP.Position - hrp.Position).Magnitude < 25 then
                                    hasTarget = true
                                    break
                                end
                            end
                        end
                    end
                end
                
                if hasTarget and lp.Character:FindFirstChildOfClass("Tool") then
                    local keys = {"Z", "X", "C", "V", "F"}
                    for _, key in pairs(keys) do
                        VIM:SendKeyEvent(true, Enum.KeyCode[key], false, game)
                        task.wait(0.05)
                        VIM:SendKeyEvent(false, Enum.KeyCode[key], false, game)
                    end
                end
            end)
        end
    end
end)

